source 'https://rubygems.org'

gemspec path: '../../'

# The minimum version of Cucumber that uses the `cucumber-gherkin` gem
gem 'cucumber', '>=4.0.0.rc.4'

if (RUBY_VERSION =~ /^4\./) && (RbConfig::CONFIG['host_os'].downcase =~ /mswin|msys|mingw32/)
  # win32ole gem stopped being included automatically after Ruby 4.0
  gem 'win32ole'
end

# Version 19 introduces a bug which is only fixed in Cucumber 11, which can not use Gherkin < 37
gem 'cucumber-cucumber-expressions', '<19'

# The version of Gherkin being tested
gem 'cucumber-gherkin', '~> 35.0'
